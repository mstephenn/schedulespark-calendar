{
  "name": "@schedulespark/calendar",
  "version": "0.0.1-beta-3-0-0",
  "description": "Framework-free schedule calendar and headless TypeScript calendar utilities.",
  "license": "MIT",
  "author": "Stephen M",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "CHANGELOG.md",
    "docs",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "./dist/styles.css",
    "./dist/playground/playground.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./playground": {
      "types": "./dist/playground/index.d.ts",
      "import": "./dist/playground/index.js"
    },
    "./playground.css": "./dist/playground/playground.css"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schedulespark/calendar.git"
  },
  "keywords": [
    "calendar",
    "schedule",
    "vanilla",
    "typescript",
    "recurrence"
  ],
  "publishConfig": {
    "access": "public",
    "tag": "beta"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && cp src/styles.css dist/styles.css && mkdir -p dist/playground && cp src/playground/playground.css dist/playground/playground.css",
    "check:bundle": "node ./scripts/check-bundle.mjs",
    "lint": "eslint src --max-warnings=0",
    "playground": "vite --config playground/vite.config.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@schedulespark/rrule": "0.0.1-beta-3-0-0"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vitest": "^4.1.10"
  }
}
