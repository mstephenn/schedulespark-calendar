{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "noEmit": true,
    "paths": {
      "@schedulespark/calendar": ["../src/index.ts"],
      "@schedulespark/calendar/styles.css": ["../src/styles.css"]
    }
  },
  "include": ["./**/*", "../src/**/*"]
}
